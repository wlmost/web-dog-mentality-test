# Dog Mentality Test - Web Application
# Umgebungsvariablen - NICHT ins Repository committen!
# Kopiere diese Datei zu .env und passe die Werte an

# === Datenbank-Konfiguration ===
DB_HOST=localhost
DB_USER=dein_datenbankuser
DB_PASS=dein_passwort
DB_NAME=dog_mentality

# === OpenAI API (optional) ===
# Für KI-Features (Idealprofil-Generierung & Bewertung)
# Erstelle deinen API Key auf: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...dein-key-hier...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TIMEOUT=30

# === Sicherheit ===
# JWT Secret für Session-Management (generiere einen zufälligen String)
JWT_SECRET=dein-geheimer-schluessel-mindestens-32-zeichen

# === Upload-Einstellungen ===
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=xlsx,xls

# === Entwicklung / Produktion ===
APP_ENV=development
DEBUG_MODE=true
